{
  "name": "dnfm-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Workspace for dnfm.kr Next.js sites.",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev:newb": "pnpm --dir newb dev",
    "dev:allow": "pnpm --dir allow dev",
    "build": "pnpm --dir newb build && pnpm --dir allow build",
    "build:newb": "pnpm --dir newb build",
    "build:allow": "pnpm --dir allow build",
    "check": "node scripts/check.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
